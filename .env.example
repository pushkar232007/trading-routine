# DO NOT fill this file in and commit it. It exists only as documentation of which
# environment variables the scripts expect. Set the real values in the Claude Code routine's
# cloud environment (Claude Desktop app -> Routines -> Environments), never in a committed file.

ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# GitHub PAT (fine-grained, scoped to this repo only, Contents: Read and write).
# Needed because the routine's built-in GitHub integration is read-only for git push.
GH_TOKEN=
